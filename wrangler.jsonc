{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "resenlegal",
  "main": "src/worker.ts",
  "compatibility_date": "2026-07-04",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
